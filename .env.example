# ESPORTEZ-MANAGER Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# WebSocket Configuration
WS_HOST=localhost
WS_PORT=8765

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/esportez

# Redis (for caching and pub/sub)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
